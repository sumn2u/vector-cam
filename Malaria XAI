atus.idle":"2026-07-19T00:46:23.750895Z","shell.execute_reply.started":"2026-07-19T00:46:22.555716Z","shell.execute_reply":"2026-07-19T00:46:23.749813Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"!pip install -q grad-cam","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-19T00:46:23.751962Z","iopub.execute_input":"2026-07-19T00:46:23.752235Z","iopub.status.idle":"2026-07-19T00:46:35.507418Z","shell.execute_reply.started":"2026-07-19T00:46:23.752207Z","shell.execute_reply":"2026-07-19T00:46:35.505688Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"import cv2\nimport torch\nimport torch.nn as nn\nimport numpy as np\nimport matplotlib.pyplot as plt\nfrom ultralytics import YOLO\nfrom pytorch_grad_cam import (EigenCAM, GradCAM, GradCAMPlusPlus, LayerCAM, HiResCAM, XGradCAM)\nfrom pytorch_grad_cam.utils.image import show_cam_on_image\n\n# ==========================================================\n# Wrapper and Target Definition\n# ==========================================================\nclass YOLOWrapper(nn.Module):\n    def __init__(self, model):\n        super().__init__()\n        self.model = model\n\n    def forward(self, x):\n        return self.model(x)\n\nclass YOLOv8Target:\n    def __init__(self, class_id=0):\n        self.class_id = class_id\n\n    def __call__(self, output):\n        if isinstance(output, (list, tuple)):\n            output = output[0]\n        if output.dim() == 2:\n            output = output.unsqueeze(0)\n        return output[:, 5 + self.class_id, :].sum()\n\n# ==========================================================\n# Setup Model\n# ==========================================================\nmodel_path = \"/kaggle/input/notebooks/sumn2u/kenya-experiments/runs/detect/train/weights/best.pt\"\nyolo = YOLO(model_path)\nnet = yolo.model\ndevice = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\nnet.to(device).train()\n\nimg_path = \"/kaggle/input/notebooks/sumn2u/kenya-experiments/test/images/image_15241_2afdce711d29cb1f511a6e6806841fac.jpg\"\nimg = cv2.resize(cv2.cvtColor(cv2.imread(img_path), cv2.COLOR_BGR2RGB), (640, 640))\ninput_tensor = torch.from_numpy(img.astype(np.float32) / 255.0).permute(2, 0, 1).unsqueeze(0).to(device)\ninput_tensor.requires_grad_(True)\n\ntarget_layers = [net.model[18], net.model[21]]\ncam_methods = {\n    \"EigenCAM\": EigenCAM, \"GradCAM\": GradCAM, \"GradCAM++\": GradCAMPlusPlus,\n    \"LayerCAM\": LayerCAM, \"HiResCAM\": HiResCAM, \"XGradCAM\": XGradCAM\n}\n\n# ==========================================================\n# Generate Combined Figure: Original + 6 CAMs + Raw Feature Map\n# ==========================================================\nplt.figure(figsize=(20, 10))\n\n# 1. Show original image\nplt.subplot(2, 4, 1)\nplt.imshow(img)\nplt.title(\"Original Image\")\nplt.axis(\"off\")\n\n# 2. Generate and show each CAM method (subplots 2-7)\nfor i, (name, CAM) in enumerate(cam_methods.items(), start=2):  # start=2 because index 1 is original\n    cam = CAM(model=YOLOWrapper(net), target_layers=target_layers, reshape_transform=None)\n    grayscale_cam = cam(input_tensor=input_tensor, targets=[YOLOv8Target(class_id=0)])[0]\n    viz = show_cam_on_image(img.astype(np.float32) / 255.0, grayscale_cam, use_rgb=True)\n    plt.subplot(2, 4, i)\n    plt.imshow(viz)\n    plt.title(f\"{name}\")\n    plt.axis(\"off\")\n\n# 3. Extract and show raw feature map from layer 21 (subplot 8)\nactivation = {}\ndef get_activation(name):\n    def hook(model, input, output):\n        activation[name] = output.detach()\n    return hook\n\nnet.model[21].register_forward_hook(get_activation('layer21'))\nwith torch.no_grad():\n    net(input_tensor)   # forward pass\n\nraw_feature_map = activation['layer21'][0, 0, :, :].cpu().numpy()   # first channel\n\nplt.subplot(2, 4, 8)\nplt.imshow(raw_feature_map, cmap='inferno')\nplt.title(\"Raw Feature Map (Layer 21)\")\nplt.axis(\"off\")\n\nplt.tight_layout()\nplt.show()\n\n# ==========================================================\n# Interpretation Summary\n# ==========================================================\nprint(\"\\n--- CAM Interpretation Guide ---\")\nprint(\"These heatmaps visualize the model's visual attention. Red/Warm areas highlight \")\nprint(\"features (shape, texture, color) contributing most to the detection of the target class.\\n\")\n\ninterpretation_summary = {\n    \"EigenCAM\": \"Uses PCA for a clean, noise-reduced view of dominant features.\",\n    \"GradCAM\": \"The foundational method highlighting generalized regions of influence.\",\n    \"GradCAM++\": \"Improved detection of multiple objects via higher-order derivatives.\",\n    \"LayerCAM\": \"Provides the finest spatial resolution, ideal for identifying exact object boundaries.\",\n    \"HiResCAM\": \"Produces sharper heatmaps with less background 'bleeding' than standard GradCAM.\",\n    \"XGradCAM\": \"An axiom-based approach providing a balanced, clear focus on the target object.\"\n}\n\nfor method, desc in interpretation_summary.items():\n    print(f\"{method}: {desc}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-19T00:46:35.510639Z","iopub.execute_input":"2026-07-19T00:46:35.511216Z","iopub.status.idle":"2026-07-19T00:47:03.957709Z","shell.execute_reply.started":"2026-07-19T00:46:35.511168Z","shell.execute_reply":"2026-07-19T00:47:03.955814Z"}},"outputs":[],"execution_count":null}]}