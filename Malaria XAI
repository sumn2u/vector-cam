    "import cv2\n",
    "import torch\n",
    "import torch.nn as nn\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from ultralytics import YOLO\n",
    "from pytorch_grad_cam import (EigenCAM, GradCAM, GradCAMPlusPlus, LayerCAM, HiResCAM, XGradCAM)\n",
    "from pytorch_grad_cam.utils.image import show_cam_on_image\n",
    "\n",
    "# ==========================================================\n",
    "# Wrapper and Target Definition\n",
    "# ==========================================================\n",
    "class YOLOWrapper(nn.Module):\n",
    "    def __init__(self, model):\n",
    "        super().__init__()\n",
    "        self.model = model\n",
    "\n",
    "    def forward(self, x):\n",
    "        return self.model(x)\n",
    "\n",
    "class YOLOv8Target:\n",
    "    def __init__(self, class_id=0):\n",
    "        self.class_id = class_id\n",
    "\n",
    "    def __call__(self, output):\n",
    "        if isinstance(output, (list, tuple)):\n",
    "            output = output[0]\n",
    "        if output.dim() == 2:\n",
    "            output = output.unsqueeze(0)\n",
    "        return output[:, 5 + self.class_id, :].sum()\n",
    "\n",
    "# ==========================================================\n",
    "# Setup Model\n",
    "# ==========================================================\n",
    "model_path = \"/kaggle/input/notebooks/sumn2u/kenya-experiments/runs/detect/train/weights/best.pt\"\n",
    "yolo = YOLO(model_path)\n",
    "net = yolo.model\n",
    "device = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n",
    "net.to(device).train()\n",
    "\n",
    "img_path = \"/kaggle/input/notebooks/sumn2u/kenya-experiments/test/images/image_15241_2afdce711d29cb1f511a6e6806841fac.jpg\"\n",
    "img = cv2.resize(cv2.cvtColor(cv2.imread(img_path), cv2.COLOR_BGR2RGB), (640, 640))\n",
    "input_tensor = torch.from_numpy(img.astype(np.float32) / 255.0).permute(2, 0, 1).unsqueeze(0).to(device)\n",
    "input_tensor.requires_grad_(True)\n",
    "\n",
    "target_layers = [net.model[18], net.model[21]]\n",
    "cam_methods = {\n",
    "    \"EigenCAM\": EigenCAM, \"GradCAM\": GradCAM, \"GradCAM++\": GradCAMPlusPlus,\n",
    "    \"LayerCAM\": LayerCAM, \"HiResCAM\": HiResCAM, \"XGradCAM\": XGradCAM\n",
    "}\n",
    "\n",
    "# ==========================================================\n",
    "# Generate Combined Figure: Original + 6 CAMs + Raw Feature Map\n",
    "# ==========================================================\n",
    "plt.figure(figsize=(20, 10))\n",
    "\n",
    "# 1. Show original image\n",
    "plt.subplot(2, 4, 1)\n",
    "plt.imshow(img)\n",
    "plt.title(\"Original Image\")\n",
    "plt.axis(\"off\")\n",
    "\n",
    "# 2. Generate and show each CAM method (subplots 2-7)\n",
    "for i, (name, CAM) in enumerate(cam_methods.items(), start=2):  # start=2 because index 1 is original\n",
    "    cam = CAM(model=YOLOWrapper(net), target_layers=target_layers, reshape_transform=None)\n",
    "    grayscale_cam = cam(input_tensor=input_tensor, targets=[YOLOv8Target(class_id=0)])[0]\n",
    "    viz = show_cam_on_image(img.astype(np.float32) / 255.0, grayscale_cam, use_rgb=True)\n",
    "    plt.subplot(2, 4, i)\n",
    "    plt.imshow(viz)\n",
    "    plt.title(f\"{name}\")\n",
    "    plt.axis(\"off\")\n",
    "\n",
    "# 3. Extract and show raw feature map from layer 21 (subplot 8)\n",
    "activation = {}\n",
    "def get_activation(name):\n",
    "    def hook(model, input, output):\n",
    "        activation[name] = output.detach()\n",
    "    return hook\n",
    "\n",
    "net.model[21].register_forward_hook(get_activation('layer21'))\n",
    "with torch.no_grad():\n",
    "    net(input_tensor)   # forward pass\n",
    "\n",
